# ============================================
# Database (Vercel Postgres / standard PostgreSQL)
# ============================================
# Pooled connection URL — used by Prisma Client at runtime
# For Vercel Postgres, map this from POSTGRES_PRISMA_URL
DATABASE_URL="postgresql://user:pass@host:port/db?pgbouncer=true&connection_limit=5"
# Direct connection URL (no pooler) — used by Prisma Migrate only
# For Vercel Postgres, map this from POSTGRES_URL_NON_POOLING
DIRECT_DATABASE_URL="postgresql://user:pass@host:port/db"

# ============================================
# Application
# ============================================
# Local dev: http://localhost:3000
# Production: https://clawdi.love
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Prefix for generated API keys
API_KEY_PREFIX="clw_dev_"

# ============================================
# LLM Provider (FLock API Platform)
# ============================================
# OpenAI-compatible base URL from FLock docs
FLOCK_API_BASE_URL="https://api.flock.io/v1"
# Create this key in platform.flock.io and send it as x-litellm-api-key
FLOCK_API_KEY=""
# Main default model for Clawdi on FLOCK.
FLOCK_DEFAULT_MODEL="kimi-k2.5"
# Default generation parameters for matchmaking-style copy and verdicts
FLOCK_MATCHMAKER_TEMPERATURE="0.3"
FLOCK_MATCHMAKER_TOP_P="0.9"
FLOCK_MATCHMAKER_MAX_TOKENS="700"
FLOCK_MATCHMAKER_SEED="7"

# ============================================
# Future: Human Auth (Auth.js)
# ============================================
# AUTH_SECRET=""
# AUTH_URL=""

# ============================================
# Future: Email (Resend)
# ============================================
# RESEND_API_KEY=""

# ============================================
# Future: Background Jobs
# ============================================
# REDIS_URL=""
# WORKER_API_SECRET=""
